---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Loïs Bilat" pageSubtitle="Senior Data & AI Engineer" activeNav="home">
    <main class="container">
        <section class="hero">
            <p class="hero-bio">
                I build intelligent systems at the intersection of AI, data engineering, and cloud platforms. With a
                Master's in Computer Science from EPFL and several years of production experience, I specialize in
                generative AI applications, NLP pipelines, IoT data platforms, and intelligent search engines.
                <br /><br />
                Outside of work I enjoy board games, running, and watching TV shows.
            </p>
            <div class="hero-links">
                <a href="/cv" class="btn btn-primary">View CV</a>
                <a href="https://linkedin.com/in/lois-bilat" target="_blank" rel="noopener" class="btn btn-outline"
                    >LinkedIn</a
                >
                <a href="https://github.com/Billotais" target="_blank" rel="noopener" class="btn btn-outline">GitHub</a>
            </div>
        </section>
    </main>
</Layout>

<style>
    .home-explore {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        padding: 0 0 96px;
    }

    @media (max-width: 480px) {
        .home-explore {
            grid-template-columns: 1fr;
        }
    }

    .home-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 24px 20px;
        text-decoration: none;
        color: inherit;
        transition:
            border-color 0.15s,
            transform 0.15s,
            box-shadow 0.15s;
    }

    .home-card:hover {
        border-color: var(--color-accent);
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        text-decoration: none;
    }

    .home-card-icon {
        font-size: 1.75rem;
        line-height: 1;
        margin-bottom: 4px;
    }

    .home-card-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--color-text);
    }

    .home-card-desc {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        line-height: 1.5;
        margin: 0;
    }
</style>

# ── Trakt ──────────────────────────────────────────────────────────────────────
# Create an app at https://trakt.tv/oauth/applications → copy Client ID + Secret
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Generated by: npm run trakt-auth  (needed for private profiles)
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=

# ── TMDB ───────────────────────────────────────────────────────────────────────
# https://developers.themoviedb.org → Settings → API → "API Read Access Token"
TMDB_READ_TOKEN=your_tmdb_read_access_token_here

# ── Vault ──────────────────────────────────────────────────────────────────────
# Optional — defaults to the local path or ./vault submodule
# VAULT_PATH=/path/to/your/vault
